menu "ZMK Soft Off Plus"

config ZMK_SOFT_OFF_PLUS
	bool "ZMK soft-off-plus"
	depends on ZMK_PM_SOFT_OFF
	default y if DT_HAS_ZMK_BEHAVIOR_SOFT_OFF_PLUS_ENABLED || DT_HAS_ZMK_SOFT_OFF_PLUS_WAKE_ENABLED || DT_HAS_ZMK_BEHAVIOR_IF_USB_ENABLED
	help
	  Umbrella switch for the soft-off-plus module. Each feature below has its
	  own option and also auto-enables when its devicetree node is present, so
	  normally you only add the nodes you want. Requires ZMK soft off
	  (CONFIG_ZMK_PM_SOFT_OFF).

if ZMK_SOFT_OFF_PLUS

#
# Feature 1: enhanced soft-off behavior (+ optional split "both halves off")
#
config ZMK_SOFT_OFF_PLUS_BEHAVIOR
	bool "Enhanced soft-off behavior (zmk,behavior-soft-off-plus)"
	default y if DT_HAS_ZMK_BEHAVIOR_SOFT_OFF_PLUS_ENABLED
	help
	  Compile the &soft_off_plus behavior. It times its hold on whichever half
	  runs it; bind it from a keymap or a dedicated power/soft-off key.

config ZMK_SOFT_OFF_PLUS_SPLIT_SYNC
	bool "Power off both split halves together"
	depends on ZMK_SOFT_OFF_PLUS_BEHAVIOR && ZMK_SPLIT && BT
	default y if ZMK_SPLIT
	help
	  Triggering soft-off-plus on either half powers off both, via a dedicated
	  GATT characteristic (the central writes an off command to its
	  peripheral(s); a peripheral notifies the central).

config ZMK_SOFT_OFF_PLUS_SPLIT_SYNC_FLUSH_MS
	int "BLE off-signal flush delay (ms)"
	depends on ZMK_SOFT_OFF_PLUS_SPLIT_SYNC
	default 60
	help
	  Wait this long after sending the cross-half off signal before powering
	  off, so the BLE write/notification is transmitted first.

#
# Feature 2: boot-time "hold to wake" delay
#
config ZMK_SOFT_OFF_PLUS_WAKE_DELAY
	bool "Require a long press to wake from soft off"
	default y if DT_HAS_ZMK_SOFT_OFF_PLUS_WAKE_ENABLED
	select HWINFO
	select POWEROFF
	help
	  After waking from soft off (a System OFF reset on nRF), poll the wake
	  GPIO(s) and only continue booting if they stay active for wake-hold-ms;
	  otherwise re-arm the wake source and return to System OFF immediately.
	  Configure with a zmk,soft-off-plus-wake devicetree node.

config ZMK_SOFT_OFF_PLUS_WAKE_DELAY_INIT_PRIORITY
	int "Wake-delay boot check init priority (POST_KERNEL)"
	depends on ZMK_SOFT_OFF_PLUS_WAKE_DELAY
	default 50
	help
	  POST_KERNEL priority of the boot-time hold check. It must run before the
	  kscan that owns the wake pins; for a matrix wake key set this low (e.g. 1).

#
# Feature 3: USB-conditional wrapper (e.g. bootloader on the power key)
#
config ZMK_SOFT_OFF_PLUS_IF_USB
	bool "USB-conditional wrapper behavior (zmk,behavior-if-usb)"
	default y if DT_HAS_ZMK_BEHAVIOR_IF_USB_ENABLED
	help
	  Compile zmk,behavior-if-usb, which forwards to a child behavior only while
	  USB is powered on the half that runs it. Use it on a dedicated
	  power/soft-off key to gate &bootloader so DFU is only reachable on the
	  half that is plugged in.

module = ZMK_SOFT_OFF_PLUS
module-str = "ZMK Soft Off Plus"
source "subsys/logging/Kconfig.template.log_config"

endif # ZMK_SOFT_OFF_PLUS

endmenu
